{
  "_comment": "Copy this file to saml.config.json and fill in your IdP details. Never commit saml.config.json.",
  "protectedMode": "none",
  "entityId": "https://your-domain.com/saml/sp",
  "acsUrl": "https://your-domain.com/saml/acs",
  "idp": {
    "metadataUrl": "https://your-idp.com/saml/metadata",
    "_comment_inline": "Or use inline fields instead of metadataUrl:",
