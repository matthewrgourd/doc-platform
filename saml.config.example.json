    "certificate": "MIIC...base64-encoded-cert...=="
  },
  "docsetRules": [
    {
      "docsetId": "tfl",
      "protected": true,
      "allowedRoles": ["admin", "maintainer", "contributor"]
    }
  ],
  "sessionDurationSeconds": 28800,
  "auditLoginFailures": true,
  "_idp_notes": {
    "okta": "Metadata URL: https://<your-okta-domain>/app/<app-id>/sso/saml/metadata",
    "azure_ad": "Metadata URL: https://login.microsoftonline.com/<tenant-id>/federationmetadata/2007-06/federationmetadata.xml",
    "google_workspace": "Download metadata XML from Admin console → Apps → SAML Apps → your app → Download metadata"
  }
