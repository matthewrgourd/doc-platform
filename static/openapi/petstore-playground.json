{
  "openapi": "3.0.3",
  "info": {
    "title": "Petstore demo API",
    "version": "1.0.0",
    "description": "Curated unauthenticated GET endpoints for demo playground use."
  },
  "servers": [
    {
      "url": "https://petstore3.swagger.io/api/v3"
    }
  ],
  "paths": {
    "/pet/findByStatus": {
      "get": {
        "summary": "Find pets by status",
        "description": "Returns pets with a requested status.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["available", "pending", "sold"],
              "default": "available"
            },
            "example": "available"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "get": {
        "summary": "Log in user",
        "description": "Logs in a user and returns a session token string.",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "theUser"
            },
            "example": "theUser"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "default": "12345"
            },
            "example": "12345"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/user/logout": {
      "get": {
        "summary": "Log out current user",
        "description": "Ends the current user session.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
